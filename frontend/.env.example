# Base URL for the Pet Management API (frozen contract §3.1).
# In local dev, leave this as `/api/v1` and let Vite proxy `/api` to the backend
# (see vite.config.ts). In other environments point it at the deployed API origin,
# e.g. https://pms.internal.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# Optional: override the dev proxy target if the backend runs somewhere other
# than http://localhost:8000. Consumed by vite.config.ts, not the app bundle.
# VITE_DEV_API_PROXY=http://localhost:8000

# Pet Management System — backend environment configuration
# Copy to `.env` and fill in real values. NEVER commit a real .env.

# Async SQLAlchemy connection string (aiomysql driver).
# Format: mysql+aiomysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+aiomysql://pms_user:change_me@localhost:3306/pet_management

# Connection pool tuning (optional — sensible defaults applied in config.py).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# CORS origins (comma-separated) — consumed by the Backend layer, kept here for completeness.
CORS_ORIGINS=http://localhost:5173
